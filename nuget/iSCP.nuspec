<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>iSCP</id>
    <version>$version$</version>
    <authors>aptpod</authors>
    <description>iSCP 2.0 client library for C#.</description>
    <copyright>Copyright © aptpod, Inc.</copyright>
    <license type="expression">Apache-2.0</license>
    <projectUrl>https://github.com/aptpod/iscp-csharp</projectUrl>
    <repository type="git" url="https://github.com/aptpod/iscp-csharp.git" />
    <readme>README.md</readme>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <tags>iscp intdash realtime streaming aptpod</tags>
    <dependencies>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Google.Protobuf" version="[3.21.9, 4.0.0)" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <file src="$artifactPath$/iSCP.dll" target="lib/netstandard2.0/iSCP.dll" />
    <file src="$artifactPath$/iSCP.xml" target="lib/netstandard2.0/iSCP.xml" />
    <file src="$readmePath$/README.md" target="README.md" />
  </files>
</package>
